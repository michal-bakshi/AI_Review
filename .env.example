# OpenAI — required
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith observability — required for tracing
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-code-review-agent

# Models (optional — these are the defaults)
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (optional — these are the defaults)
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=coding_standards

# Fine-tuning data — local: ./data; Render with persistent disk: /data
DATA_DIR=./data

# CORS — comma-separated list of allowed frontend origins (optional)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SSE streaming — seconds to wait between words (optional)
SSE_WORD_DELAY=0.04
